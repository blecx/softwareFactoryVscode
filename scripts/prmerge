#!/bin/bash
set -e
if [[ "$1" == "--force-bypass" ]]; then
  CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
  export CURRENT_BRANCH

  if ! python3 -c "
import sys
import os
import json
sys.path.insert(0, os.path.abspath(os.path.join(os.getcwd())))
from scripts.workflow_preflight_gate import verify_preflight_evidence, get_evidence_path
try:
    exact = {'branch': os.environ.get('CURRENT_BRANCH'), 'break_glass': True}
    verify_preflight_evidence('force-bypass', 'human-operator', 600, exact_state=exact)
    evidence_path = get_evidence_path('force-bypass')
    with open(evidence_path, 'r') as f:
        evidence = json.load(f)
    bypass_ev = evidence.get('exact_state', {}).get('bypass_evidence', '')
    if not bypass_ev or len(str(bypass_ev).strip()) == 0:
        print('Hard-gate bypass failed: bypass_evidence is empty or missing in the recorded evidence.', file=sys.stderr)
        sys.exit(1)
except Exception as e:
    print(f'Hard-gate bypass failed: {e}', file=sys.stderr)
    sys.exit(1)
"; then
      exit 1
  fi
  echo "Bypass authorized."
  gh pr merge --squash
  exit 0
fi

# Determine branch
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
export CURRENT_BRANCH

# Run python preflight gate
if ! python3 -c "
import sys
import os
sys.path.insert(0, os.path.abspath(os.path.join(os.getcwd())))
from scripts.workflow_preflight_gate import verify_preflight_evidence
try:
    exact = {'branch': os.environ.get('CURRENT_BRANCH')}
    verify_preflight_evidence('issue-workflow', 'copilot-workspace', 300, exact_state=exact)
except Exception as e:
    import traceback
    traceback.print_exc()
    print(f'Preflight gate failed: {e}', file=sys.stderr)
    sys.exit(1)
"; then
    exit 1
fi

if [[ ! -f ".tmp/validation-receipt.json" ]]; then
  echo "❌ Missing .tmp/validation-receipt.json! You must validate first."
  exit 1
fi
echo "Receipt found. Proceeding with merge."
gh pr merge --squash
